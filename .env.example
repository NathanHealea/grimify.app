# Supabase
# When using local Supabase, these are printed by `supabase start`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OAuth Providers (optional — only needed for social login)
# These go in supabase/.env.local for Supabase CLI, not here.
# SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# SUPABASE_AUTH_EXTERNAL_DISCORD_CLIENT_ID=
# SUPABASE_AUTH_EXTERNAL_DISCORD_SECRET=
