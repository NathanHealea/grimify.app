NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — required for admin API calls (ban/unban, auth metadata).
# Never expose this to the client. Set in Vercel environment variables as a server-only secret.
SUPABASE_SECRET_KEY=

# Cloudflare Turnstile — human verification on sign-in and sign-up.
# Site key is rendered into the client widget; secret key verifies tokens server-side.
# Provision keys at https://dash.cloudflare.com/?to=/:account/turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
