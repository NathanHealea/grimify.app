{
  "name": "grimify.app",
  "version": "1.20.0",
  "description": "Interactive color research and collection management app for miniature painters",
  "author": "Nathan Healea <nhealea@uoregon.edu>",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prettify": "prettier --write .",
    "format": "prettier --write . && eslint --fix",
    "db:start": "npx supabase start",
    "db:stop": "npx supabase stop",
    "db:restart": "npx supabase stop && npx supabase start",
    "db:reset": "npx supabase db reset",
    "db:status": "npx supabase status",
    "db:types": "npx supabase gen types typescript --local > src/types/supabase.ts",
    "db:seed:generate": "npx tsx scripts/generate-seed.ts",
    "db:paints:recalculate": "node --env-file=.env node_modules/.bin/tsx scripts/recalculate-paint-colors.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
